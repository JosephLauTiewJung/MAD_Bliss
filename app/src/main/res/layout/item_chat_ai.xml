<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp"
    android:gravity="start"> <TextView
    android:id="@+id/text_chat_user_ai"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="BlissMate"
    android:textColor="#757575"
    android:textSize="12sp"
    android:textStyle="bold" />

    <TextView
        android:id="@+id/text_chat_message_ai"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:background="@drawable/bg_bubble_ai"
        android:padding="12dp"
        android:text="Sample AI response"
        android:textColor="#333333"
        android:textSize="15sp"
        android:maxWidth="280dp" />

    <TextView
        android:id="@+id/text_chat_timestamp_ai"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="10:01 AM"
        android:textColor="#999999"
        android:textSize="10sp" />

</LinearLayout>